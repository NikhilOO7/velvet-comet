# Velvet Comet — copy to .env (never commit .env). All config is validated at startup.

# Firecrawl
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# Plan-derived budgets for the chokepoint (see PLAN.md §6a). Defaults = Growth plan.
FIRECRAWL_RPM=5000
FIRECRAWL_MAX_CONCURRENCY=100

# LLM (query expansion + intent scoring leaf stages)
ANTHROPIC_API_KEY=sk-ant-...

# Infra (used once worker/api packages land)
DATABASE_URL=postgres://localhost:5432/velvet_comet
REDIS_URL=redis://localhost:6379

# Contract tests against live Firecrawl run only when this is set in CI
RUN_LIVE_CONTRACT_TESTS=false
